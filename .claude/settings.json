{
  "deniedMcpServers": [
    { "serverName": "github" }
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./boot-ccotw.sh 2>&1 || echo 'Boot failed (non-fatal)'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./persist-transcript.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./persist-transcript.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); p=d.get('tool_input',d).get('file_path',''); exit(0 if 'Containerfile' in p else 1)\" && { nohup bash ./rebuild-layer.sh >/dev/null 2>&1 & }; true"
          }
        ]
      }
    ]
  }
}
