{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && bash ./boot-ccotw.sh 2>&1 || echo 'Boot failed (non-fatal)'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && python3 ./scripts/check-store-on-stop.py 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && bash ./persist-transcript.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && bash ./persist-transcript.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && bash ./scripts/ensure-scope.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && bash ./scripts/inject-identity.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && python3 ./scripts/derive-session-title.py 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && bash ./scripts/rebuild-status.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && bash ./scripts/smoke-status.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/Containerfile)",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && nohup bash ./rebuild-layer.sh >/dev/null 2>&1 & true"
          },
          {
            "type": "command",
            "if": "Write(**/Containerfile)",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && nohup bash ./rebuild-layer.sh >/dev/null 2>&1 & true"
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && python3 ./scripts/tdd_hook.py posttooluse 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && python3 ./scripts/trim-tool-output.py 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && python3 ./scripts/tdd_hook.py pretooluse 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-/home/user/claude-workspace-fuse}\" && python3 ./pre-compact-flush.py 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
