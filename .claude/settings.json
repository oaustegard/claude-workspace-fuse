{
  "deniedMcpServers": [
    { "serverName": "github" }
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./boot-ccotw.sh 2>&1 || echo 'Boot failed (non-fatal)'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./persist-transcript.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./persist-transcript.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/derive-session-title.py 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/Containerfile)",
            "command": "nohup bash ./rebuild-layer.sh >/dev/null 2>&1 & true"
          },
          {
            "type": "command",
            "if": "Write(**/Containerfile)",
            "command": "nohup bash ./rebuild-layer.sh >/dev/null 2>&1 & true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/trim-tool-output.py 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./pre-compact-flush.py 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
