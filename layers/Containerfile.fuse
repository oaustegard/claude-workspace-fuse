# FUSE Python bindings (libfuse2 + fusermount are already in base container).
# Cached as layer-fuse-<hash>.
#
# The 2026-05-17 build pre-dated bf52f5e's SNAPSHOT-diff fix, so its
# tarball captured the entire post-base dist-packages tree (~666MB)
# instead of just fusepy (~50KB). The cached blob silently carried
# pysr + mojo + other monolithic-layer crud back into every session,
# defeating the manifest. Re-cut here against the current diff-aware
# skill (issue #20, Test 2 FAIL diagnostic).
# cache-bust: 2026-05-17b

RUN uv pip install --system --break-system-packages fusepy

SNAPSHOT /usr/local/lib/python3.11/dist-packages
